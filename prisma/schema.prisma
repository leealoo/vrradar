generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Feed {
  id        String    @id @default(cuid())
  name      String
  url       String    @unique
  type      String    @default("RSS")
  enabled   Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  articles  Article[]
  crawlFeedback CrawlFeedback[]
}

model Article {
  id          String    @id @default(cuid())
  title           String
  translatedTitle String    @default("")
  link        String    @unique
  source      String
  publishedAt DateTime?
  publishedAtSource String    @default("UNKNOWN")
  discoveredFromUrl String    @default("")
  extractionMethod String    @default("LEGACY")
  contextSignature String    @default("LEGACY")
  companyTags String    @default("[]")
  topicTags   String    @default("[]")
  favorite    Boolean   @default(false)
  favoritedAt DateTime?
  note        String    @default("")
  deleted     Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  feedId      String?
  feed        Feed?     @relation(fields: [feedId], references: [id], onDelete: SetNull)
  crawlFeedback CrawlFeedback?
}

model CrawlFeedback {
  id                String   @id @default(cuid())
  articleId         String   @unique
  feedId            String?
  siteHost          String
  verdict           String
  origin            String   @default("USER")
  titleSnapshot     String
  linkSnapshot      String
  normalizedLink    String
  discoveredFromUrl String   @default("")
  extractionMethod  String   @default("LEGACY")
  contextSignature  String   @default("LEGACY")
  pathKind           String   @default("OTHER")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  article           Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  feed              Feed?    @relation(fields: [feedId], references: [id], onDelete: SetNull)

  @@index([siteHost, verdict])
  @@index([feedId, verdict])
}

model TagRule {
  id        String      @id @default(cuid())
  category  String
  label     String
  keywords  String      @default("[]")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([category, label])
}

model SavedSearchKeyword {
  id        String   @id @default(cuid())
  keyword   String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AppSetting {
  key       String   @id
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
